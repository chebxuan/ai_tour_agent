{
  "name": "travel_planner_api",
  "description": "旅游规划智能助手API服务",
  "version": "1.0.0",
  "functions": [
    {
      "name": "get_city_survey",
      "description": "根据城市生成旅游需求问卷",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "目标城市名称",
            "enum": ["北京", "上海", "广州", "重庆", "西安", "阳朔", "张家界", "贵州", "云南", "成都"]
          }
        },
        "required": ["city"]
      }
    },
    {
      "name": "get_product_recommendation",
      "description": "根据用户需求获取旅游产品推荐",
      "parameters": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string",
            "description": "目标城市"
          },
          "days": {
            "type": "number",
            "description": "旅游天数"
          },
          "adults": {
            "type": "number",
            "description": "成人数量"
          },
          "children": {
            "type": "number",
            "description": "儿童数量"
          },
          "seniors": {
            "type": "number",
            "description": "老人数量"
          },
          "is_peak": {
            "type": "boolean",
            "description": "是否为旺季"
          },
          "hotel": {
            "type": "string",
            "description": "酒店类型"
          },
          "transfer": {
            "type": "string",
            "description": "交通类型"
          },
          "car_days": {
            "type": "number",
            "description": "包车天数"
          },
          "transfer_times": {
            "type": "number",
            "description": "接送次数"
          },
          "selected_optional": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "选择的可选项目列表"
          }
        },
        "required": ["city", "days", "adults"]
      }
    },
    {
      "name": "calculate_total_cost",
      "description": "计算旅游总费用",
      "parameters": {
        "type": "object",
        "properties": {
          "product_recommendation": {
            "type": "object",
            "description": "产品推荐结果"
          }
        },
        "required": ["product_recommendation"]
      }
    },
    {
      "name": "list_available_cities",
      "description": "获取可用的城市列表",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ],
  "events": [
    {
      "name": "session_start",
      "description": "会话开始事件",
      "parameters": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "用户ID"
          },
          "session_id": {
            "type": "string",
            "description": "会话ID"
          }
        }
      }
    },
    {
      "name": "plan_completed",
      "description": "行程规划完成事件",
      "parameters": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "用户ID"
          },
          "city": {
            "type": "string",
            "description": "规划城市"
          },
          "total_cost": {
            "type": "number",
            "description": "总费用"
          }
        }
      }
    }
  ]
}